package trabajoPROG;

import java.util.ArrayList;
import java.util.List;

/**
 * Clase que representa una línea de un pedido.
 */
public class LineaPedido {

    private double descuentoAplicado;
    private String codigoSKU;
    private double precioUnitario;
    private int cantidad;
    private String nombreProducto;
    private List<String> listadoCliente;
    private List<String> listadoArticulos;

    /**
     * Crea una línea de pedido.
     *
     * @param descuentoAplicado descuento aplicado
     * @param codigoSKU código del producto
     * @param precioUnitario precio por unidad
     * @param cantidad cantidad pedida
     * @param nombreProducto nombre del producto
     */
    public LineaPedido(double descuentoAplicado, String codigoSKU,
                       double precioUnitario, int cantidad, String nombreProducto) {
        this.descuentoAplicado = descuentoAplicado;
        this.codigoSKU = codigoSKU;
        this.precioUnitario = precioUnitario;
        this.cantidad = cantidad;
        this.nombreProducto = nombreProducto;
        this.listadoCliente = new ArrayList<>();
        this.listadoArticulos = new ArrayList<>();
    }

    /** @return descuento aplicado */
    public double getDescuentoAplicado() {
        return descuentoAplicado;
    }

    /** @param descuentoAplicado descuento a aplicar */
    public void setDescuentoAplicado(double descuentoAplicado) {
        this.descuentoAplicado = descuentoAplicado;
    }

    /** @return código SKU */
    public String getCodigoSKU() {
        return codigoSKU;
    }

    /** @param codigoSKU código SKU */
    public void setCodigoSKU(String codigoSKU) {
        this.codigoSKU = codigoSKU;
    }

    /** @return precio unitario */
    public double getPrecioUnitario() {
        return precioUnitario;
    }

    /** @param precioUnitario precio unitario */
    public void setPrecioUnitario(double precioUnitario) {
        this.precioUnitario = precioUnitario;
    }

    /** @return cantidad */
    public int getCantidad() {
        return cantidad;
    }

    /** @param cantidad cantidad del producto */
    public void setCantidad(int cantidad) {
        this.cantidad = cantidad;
    }

    /** @return nombre del producto */
    public String getNombreProducto() {
        return nombreProducto;
    }

    /** @param nombreProducto nombre del producto */
    public void setNombreProducto(String nombreProducto) {
        this.nombreProducto = nombreProducto;
    }

    /** @return lista de clientes */
    public List<String> getListadoCliente() {
        return listadoCliente;
    }

    /** @return lista de artículos */
    public List<String> getListadoArticulos() {
        return listadoArticulos;
    }
}
